DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database — V2 targets PostgreSQL. Set DB_ENGINE=postgres and fill in the
# credentials below (DB_PASSWORD = the password chosen when PostgreSQL was
# installed). Leave DB_ENGINE unset/sqlite to fall back to SQLite for dev.
DB_ENGINE=postgres
DB_NAME=nacc_v2
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Uploaded files (reports, signed consent scans)
# MEDIA_ROOT=  # defaults to backend/media
FILE_UPLOAD_MAX_MB=15
